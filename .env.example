# ResinRiva — Environment Variables (names only, no secrets)
# Copy to .env.local for local development. Most values are auto-injected by
# Vercel-native integrations; pull them with: vercel env pull .env.local

# --- Database (Neon Postgres via Vercel Marketplace) ---
# AUTO-INJECTED by the Neon native integration. Pull locally with `vercel env pull`.
DATABASE_URL=

# --- Auth.js v5 (NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://shop.bhavyagondaliya.co.in

# --- Admin (owner-only login at /studio) ---
ADMIN_EMAIL=gondaliyabhavya70960@gmail.com
ADMIN_PASSWORD=                 # used by the seed script only; not read at runtime

# --- Vercel Blob (media storage) ---
# AUTO-INJECTED when the Vercel Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN=

# --- Email (optional — Resend via Vercel Marketplace) ---
RESEND_API_KEY=

# --- Public (exposed to the browser) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=917096036250
NEXT_PUBLIC_SITE_URL=https://shop.bhavyagondaliya.co.in
